# .env.example
#
# Copy this file to .env and fill in real values before running
# `docker compose up`. Never commit the actual .env file — it is
# excluded via .gitignore (Section 24.3, Secrets Management).

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RIDE_REQUESTS=ride-requests
KAFKA_TOPIC_DLQ=ride-requests-dlq
KAFKA_CONSUMER_GROUP=ride-demand-spark-consumer

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ride_demand
POSTGRES_USER=ride_demand_app
POSTGRES_PASSWORD=change_me_before_deploying

# --- Machine Learning ---
ML_MODEL_PATH=/app/ml/artifacts/demand_model_latest.pkl
ML_MODEL_VERSION=v1.0
ML_PREDICTION_WINDOW_MINUTES=15

# --- API ---
API_KEY=change_me_to_a_random_secret
API_HOST=0.0.0.0
API_PORT=8000

# --- Dashboard ---
API_BASE_URL=http://backend:8000

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
